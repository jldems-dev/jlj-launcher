{
  "name": "jljgaminghouse",
  "version": "1.0.17",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electronmon .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.jljgaminghouse.menu",
    "productName": "JLJGAMINGHOUSE",
    "publish": [
      {
        "provider": "github",
        "owner": "jldems-dev",
        "repo": "jlj-launcher",
        "releaseType": "draft"
      }
    ],
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/images/favicon-512x512.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "electronmon": "^2.0.4"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "buffer-crc32": "^0.2.13",
    "cheerio": "^1.0.0-rc.12",
    "debug": "^4.4.3",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.3",
    "end-of-stream": "^1.4.5",
    "env-paths": "^3.0.0",
    "extract-zip": "^2.0.1",
    "fd-slicer": "^1.1.0",
    "get-stream": "^5.2.0",
    "graceful-fs": "^4.2.11",
    "ms": "^2.1.3",
    "once": "^1.4.0",
    "pend": "^1.2.0",
    "progress": "^2.0.3",
    "pump": "^3.0.4",
    "robotjs": "^0.7.1",
    "screenshot-desktop": "^1.15.4",
    "semver": "^7.8.0",
    "socket.io-client": "^4.8.3",
    "sudo-prompt": "^9.2.1",
    "sumchecker": "^3.0.1",
    "systeminformation": "^5.31.6",
    "undici": "^5.29.0",
    "undici-types": "^7.16.0",
    "wrappy": "^1.0.2",
    "yauzl": "^2.10.0"
  }
